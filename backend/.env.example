# =============================================================================
# Zabatly Backend — Environment Variables
# Copy this to .env and fill in your values.
# =============================================================================

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Database (PostgreSQL on VPS) ─────────────────────────────────────────────
DATABASE_URL=postgresql://zabatly_user:your_password@localhost:5432/zabatly

# ─── Auth (Custom JWT) ────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-min-64-chars
JWT_EXPIRES_IN=7d

# ─── Storage ──────────────────────────────────────────────────────────────────
# Option A — Local disk (default, cheapest):
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=/var/www/zabatly/uploads
STORAGE_BASE_URL=https://api.zabatly.com/uploads

# Option B — Cloudflare R2 (~$0–2/mo, no egress fees):
# STORAGE_DRIVER=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=zabatly
# R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ─── AI (fal.ai — images + LLM) ──────────────────────────────────────────────
FAL_KEY=your-fal-ai-api-key
# Optional: override default LLM model (default: google/gemini-flash-1.5)
# FAL_LLM_MODEL=google/gemini-flash-1.5

# ─── Email (optional — skip for now) ─────────────────────────────────────────
# RESEND_API_KEY=re_...
# EMAIL_FROM=Zabatly <hello@zabatly.com>
# ADMIN_EMAIL=admin@zabatly.com

# ─── Payments ─────────────────────────────────────────────────────────────────
INSTAPAY_PHONE=01211100767
VODAFONE_CASH_PHONE=01044443752
INSTAPAY_ACCOUNT_NAME=Zabatly
PLAN_PRICE_BASIC=39
PLAN_PRICE_PREMIUM=79
PLAN_PRICE_PER_BOARD=10
PLAN_PRICE_PER_REDESIGN=15

# ─── n8n Webhooks (optional) ──────────────────────────────────────────────────
N8N_WEBHOOK_SECRET=your-n8n-secret-token
N8N_MOODBOARD_WEBHOOK_URL=https://n8n.yourdomain.com/webhook/moodboard
N8N_PAYMENT_WEBHOOK_URL=https://n8n.yourdomain.com/webhook/payment

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5
PAYMENT_RATE_LIMIT_MAX=3
